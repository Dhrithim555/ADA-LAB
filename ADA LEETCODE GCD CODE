int GCD (int a , int b) {
    while ( b != 0) {
        int temp = b ;
        b = a % b ;
        a = temp ;
    }
    return a ;
}

int findGCD (int * nums , int numsize) {
    int min = nums [0] ;
    int max = nums [0] ;

    for (int i = 1 ; i < numsize ; i++) {
        if (nums [i] < min)
            min = nums [i] ;

        if (nums [i] > max)
            max = nums [i] ;
    }

    return GCD (min , max) ;
}
