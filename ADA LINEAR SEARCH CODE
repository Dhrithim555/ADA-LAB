#include <stdio.h>
int main() {
    int arr[100], n, key, pos = -1;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    printf("Enter elements:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);
    printf("Enter element to search: ");
    scanf("%d", &key);
    for (int i = 0; i < n; i++) {
        if (arr[i] == key) {
            pos = i;
            break;
        }
    }
    if (pos == -1) {
        printf("Element not found\n");
    } else {
        printf("Element found at position: %d\n", pos + 1);
    }
    return 0;
}
