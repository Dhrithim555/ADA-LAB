#include <stdio.h>
int mobile(int a[], int dir[], int n) {
    int m = 0, idx = -1;
    for (int i = 0; i < n; i++) {
        if ((dir[i] == -1 && i > 0 && a[i] > a[i-1]) ||
            (dir[i] == 1 && i < n-1 && a[i] > a[i+1])) {
            if (a[i] > m) {
                m = a[i];
                idx = i;
            }
        }
    }
    return idx;
}
void jt(int n) {
    int a[n], dir[n], step = 1;
    for (int i = 0; i < n; i++) {
        a[i] = i + 1;
        dir[i] = -1;
    }
    while (1) {
        printf("Permutation %d: ", step++);
        for (int i = 0; i < n; i++) printf("%d ", a[i]);
        printf("\n");
        int i = mobile(a, dir, n);
        if (i == -1) break;
        int j = i + dir[i];
        int t = a[i]; a[i] = a[j]; a[j] = t;
        t = dir[i]; dir[i] = dir[j]; dir[j] = t;
        for (int k = 0; k < n; k++)
            if (a[k] > a[j]) dir[k] *= -1;
    }
}
int main() {
    int n;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    printf("\nGenerated permutations using Johnson-Trotter algorithm:\n\n");
    jt(n);
    return 0;
}
