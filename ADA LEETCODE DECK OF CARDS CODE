int gcd (int a , int b)
{
    while (b)
    {
        int t = b ;
        b = a % b ;
        a = t ;
    }
    return a ;
}

bool hasGroupsSizeX (int* deck , int decksize)
{
    int count [10001] = {0} ;
    int g = 0 ;

    for (int i = 0 ; i < decksize ; i++)
        count [deck[i]]++ ;

    for (int i = 0 ; i < 10001 ; i++)
        if (count [i] > 0)
            if (g == 0)
                g = count [i] ;
            else
                g = gcd (g , count [i]) ;

    return g >= 2 ;
}
