#include <stdbool.h>

int gcd (int a , int b) {
    while (b) {
        int t = b ;
        b = a % b ;
        a = t ;
    }
    return a ;
}

bool isGoodArray (int * nums , int numsize)
{
    int g = nums [0] ;

    for (int i = 1 ; i < numsize ; i++) {
        g = gcd (g , nums [i]) ;
    }

    return g == 1 ;
}
